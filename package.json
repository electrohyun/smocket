{
  "name": "smocket",
  "version": "0.0.1",
  "description": "Socket.IO mock for frontend development and testing — with full room, namespace, and broadcast support. (Work in progress: under active development and not yet functional.)",
  "type": "module",
  "license": "MIT",
  "author": "electrohyun",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/electrohyun/smocket.git"
  },
  "bugs": "https://github.com/electrohyun/smocket/issues",
  "homepage": "https://github.com/electrohyun/smocket#readme",
  "keywords": [
    "socket.io",
    "socketio",
    "websocket",
    "mock",
    "mocking",
    "testing",
    "test-utils",
    "typescript"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "test": "vitest",
    "test:mock": "SMOCKET_TARGET=mock vitest run",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.15.1",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
